includes:
	- %rootDir%/../../konradmichalik/phpstan-typo3-preset/phpstan.neon.dist
	- vendor/phpstan/phpstan-phpunit/extension.neon
	- vendor/phpstan/phpstan-phpunit/rules.neon
	- phpstan-baseline.neon

parameters:
	level: max

	scanDirectories:
		- ../../vendor
	paths:
		- ../../Classes
		- ../../Configuration
		- ../../Tests/Unit

	type_coverage:
		constant: 0 # TODO: Set to 100, when PHP 8.3 is minimum requirement

	ignoreErrors:
		# Tests legitimately toggle the trace flag via the environment.
		-
			message: '#^Calling putenv\(\) is forbidden, might overwrite existing variables\.$#'
			paths:
				- ../../Tests/Unit/ConfigurationTest.php
				- ../../Tests/Unit/Profiling/Instrumentation/Doctrine/QueryOriginTest.php
				- ../../Tests/Unit/Profiling/Instrumentation/Doctrine/ProfilingConnectionTest.php
				- ../../Tests/Unit/Profiling/Section/EventsSectionTest.php
